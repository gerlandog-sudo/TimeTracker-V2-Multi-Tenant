<?php
declare(strict_types=1);

require_once __DIR__ . '/src/Database.php';
require_once __DIR__ . '/src/Auth.php';

use App\Database;
use App\Auth;

header('Content-Type: application/json');
header('Access-Control-Allow-Origin: *');
header('Access-Control-Allow-Methods: GET, POST, PUT, DELETE, PATCH, OPTIONS');
header('Access-Control-Allow-Headers: Content-Type, Authorization');

if ($_SERVER['REQUEST_METHOD'] === 'OPTIONS') {
    exit;
}

$method = $_SERVER['REQUEST_METHOD'];

// Robust path detection
$path = $_GET['path'] ?? null;
if (!$path) {
    $requestUri = $_SERVER['REQUEST_URI'];
    $scriptName = $_SERVER['SCRIPT_NAME'];
    
    // Remove query string
    $requestUri = explode('?', $requestUri)[0];
    
    // Base path detection
    $basePath = str_replace('index.php', '', $scriptName);
    if ($basePath !== '/' && strpos($requestUri, $basePath) === 0) {
        $path = substr($requestUri, strlen($basePath));
    } else {
        $path = $requestUri;
    }
}
$path = trim((string)$path, '/');
// Remove index.php if it's at the start of the path
if (strpos($path, 'index.php') === 0) {
    $path = trim(substr($path, 9), '/');
}

// Helper to get JSON body
function getBody() {
    return json_decode(file_get_contents('php://input'), true) ?? [];
}

/**
 * Muro de Seguridad Financiera (Financial Masking Guard)
 * Elimina completamente los campos financieros si el role_id del usuario > 2.
 */
function maskFinancialData($payload, $role_id) {
    if ($role_id <= 2) return $payload;

    $financial_fields = [
        'budget_money', 'hourly_rate', 'total_actual_revenue', 
        'total_budget_money', 'cost', 'margin', 'hourly_cost'
    ];

    if (is_array($payload)) {
        // En PHP un array puede ser tanto asociativo (objeto JS) como lista
        $isAssoc = !empty($payload) && array_keys($payload) !== range(0, count($payload) - 1);
        
        if ($isAssoc) {
             foreach ($financial_fields as $field) {
                 if (array_key_exists($field, $payload)) {
                     unset($payload[$field]);
                 }
             }
             foreach ($payload as $key => &$value) {
                 if (is_array($value)) {
                     $value = maskFinancialData($value, $role_id);
                 }
             }
        } else {
             foreach ($payload as &$item) {
                 if (is_array($item)) {
                     $item = maskFinancialData($item, $role_id);
                 }
             }
        }
    }
    return $payload;
}

// Intercepta las llamadas a json_encode para inyectar el Guard de forma centralizada si existe un usuario autenticado
function jsonResponse($data, $status = 200) {
    http_response_code($status);
    $user = Auth::getAuthenticatedUser();
    if ($user && isset($user['role_id'])) {
        $data = maskFinancialData($data, (int)$user['role_id']);
    }
    echo json_encode($data);
    exit;
}

function logTransition($timeEntryId, $fromStatus, $toStatus, $userId, $comment = null) {
    Database::query("
        INSERT INTO time_entry_logs (time_entry_id, from_status, to_status, user_id, comment) 
        VALUES (?, ?, ?, ?, ?)
    ", [$timeEntryId, $fromStatus, $toStatus, $userId, $comment]);
}

function createNotification($userId, $message, $type = 'info') {
    Database::query("
        INSERT INTO notifications (user_id, message, type) 
        VALUES (?, ?, ?)
    ", [$userId, $message, $type]);
}

function hasPermission($user, $feature) {
    if (!$user) return false;
    // role_id 1 is admin
    if ((int)$user['role_id'] === 1) return true;
    
    try {
        $res = Database::fetchOne("SELECT can_access FROM permissions WHERE role_id = ? AND feature = ? LIMIT 1", [(int)$user['role_id'], $feature]);
        return $res && (int)$res['can_access'] === 1;
    } catch (Throwable $e) {
        return false;
    }
}

// --- ROUTES ---

try {
    // 1. Auth Login
    if ($path === 'auth/login' && $method === 'POST') {
        $body = getBody();
        $email = $body['email'] ?? '';
        $password = $body['password'] ?? '';
        
        $user = Database::fetchOne("SELECT * FROM users WHERE email = ?", [$email]);
        
        if ($user && password_verify($password, $user['password'])) {
            $token = Auth::generateToken([
                'id' => $user['id'],
                'email' => $user['email'],
                'role' => $user['role'],
                'role_id' => $user['role_id'],
                'language' => $user['language'] ?? 'es_AR',
                'exp' => time() + (24 * 60 * 60) // 24h
            ]);
            
            unset($user['password']);
            jsonResponse(['token' => $token, 'user' => $user]);
        } else {
            http_response_code(401);
            jsonResponse(['message' => 'Credenciales inválidas']);
        }
        exit;
    }

    // Auth Forgot Password
    if ($path === 'auth/forgot-password' && $method === 'POST') {
        $body = getBody();
        $email = $body['email'] ?? '';
        
        $user = Database::fetchOne("SELECT id FROM users WHERE email = ?", [$email]);
        
        if ($user) {
            $otp = (string)rand(100000, 999999);
            $expiresAt = date('Y-m-d H:i:s', strtotime('+15 minutes'));
            
            Database::query("INSERT INTO password_resets (email, otp, expires_at) VALUES (?, ?, ?)", [$email, $otp, $expiresAt]);
            
            // Send Email
            $subject = "TimeTracker - Código de Verificación";
            $message = "Tu código para resetear la contraseña es: $otp\nEste código expira en 15 minutos.";
            $headers = "From: noreply@timetracker.pmaasglobal.com";
            
            // In cPanel environment, mail() usually works if configured
            @mail($email, $subject, $message, $headers);
            
            jsonResponse(['success' => true, 'message' => 'Código enviado']);
        } else {
            // Unify response for security (don't reveal if email exists)
            jsonResponse(['success' => true, 'message' => 'Si el email existe, se enviará un código']);
        }
        exit;
    }

    // Auth Reset Password
    if ($path === 'auth/reset-password' && $method === 'POST') {
        $body = getBody();
        $email = $body['email'] ?? '';
        $otp = $body['otp'] ?? '';
        $newPassword = $body['password'] ?? '';
        
        $reset = Database::fetchOne("
            SELECT * FROM password_resets 
            WHERE email = ? AND otp = ? AND used = 0 AND expires_at > NOW() 
            ORDER BY created_at DESC LIMIT 1
        ", [$email, $otp]);
        
        if ($reset) {
            $hashedPassword = password_hash($newPassword, PASSWORD_DEFAULT);
            Database::query("UPDATE users SET password = ? WHERE email = ?", [$hashedPassword, $email]);
            Database::query("UPDATE password_resets SET used = 1 WHERE id = ?", [$reset['id']]);
            
            jsonResponse(['success' => true, 'message' => 'Contraseña actualizada']);
        } else {
            http_response_code(400);
            jsonResponse(['message' => 'Código inválido o expirado']);
        }
        exit;
    }

    // 2. System Config
    if ($path === 'reports/heatmap' && $method === 'GET') {
        $user = Auth::getAuthenticatedUser();
        if (!$user) { http_response_code(401); jsonResponse(['error' => 'Unauthorized']); exit; }
        
        // Check permission
        if (!hasPermission($user, 'report_heatmaps')) {
            http_response_code(403); jsonResponse(['error' => 'Forbidden']); exit;
        }

        $startDate = $_GET['start_date'] ?? date('Y-m-d', strtotime('monday this week'));
        $endDate = $_GET['end_date'] ?? date('Y-m-d', strtotime('sunday this week'));

        // Get all users with their weekly capacity (Exclude Admins)
        $users = Database::fetchAll("SELECT id, name, weekly_capacity FROM users WHERE role_id != 1 ORDER BY name");
        
        // Get all time entries for the period (excluding rejected and excluding admin entries)
        $entries = Database::fetchAll("
            SELECT t.user_id, t.date, SUM(t.hours) as total_hours 
            FROM time_entries t
            JOIN users u ON t.user_id = u.id
            WHERE t.date >= ? AND t.date <= ? AND t.status IN ('draft', 'submitted', 'approved') AND u.role_id != 1
            GROUP BY t.user_id, t.date
        ", [$startDate, $endDate]);

        // Organize data
        $heatmapData = [];
        foreach ($users as $u) {
            $weeklyCapacity = (float)$u['weekly_capacity'];
            
            $userDays = [];
            $userWeeks = [];
            
            // Initialize all days in range
            $current = strtotime($startDate);
            $end = strtotime($endDate);
            while ($current <= $end) {
                $dateStr = date('Y-m-d', $current);
                $weekStr = date('Y-W', $current);
                
                $userDays[$dateStr] = [
                    'date' => $dateStr,
                    'hours' => 0,
                    'saturation' => 0
                ];
                
                if (!isset($userWeeks[$weekStr])) {
                    $userWeeks[$weekStr] = [
                        'week' => $weekStr,
                        'hours' => 0,
                        'saturation' => 0
                    ];
                }
                
                $current = strtotime('+1 day', $current);
            }

            // Fill with actual data
            foreach ($entries as $e) {
                if ($e['user_id'] == $u['id']) {
                    if (isset($userDays[$e['date']])) {
                        $hours = (float)$e['total_hours'];
                        $userDays[$e['date']]['hours'] = $hours;
                        // Daily saturation: hours registered that day relative to a standard 8-hour day
                        $userDays[$e['date']]['saturation'] = ($hours / 8) * 100;
                        
                        // Accumulate for weekly
                        $weekStr = date('Y-W', strtotime($e['date']));
                        if (isset($userWeeks[$weekStr])) {
                            $userWeeks[$weekStr]['hours'] += $hours;
                        }
                    }
                }
            }
            
            // Calculate weekly saturation based on weekly capacity
            foreach ($userWeeks as &$week) {
                $week['saturation'] = $weeklyCapacity > 0 ? (($week['hours'] / $weeklyCapacity) * 100) : 0;
            }

            $heatmapData[] = [
                'user_id' => $u['id'],
                'user_name' => $u['name'],
                'weekly_capacity' => $weeklyCapacity,
                'days' => array_values($userDays),
                'weeks' => array_values($userWeeks)
            ];
        }

        jsonResponse($heatmapData);
        exit;
    }

    // 2.1 Audit Log Report
    if ($path === 'reports/audit' && $method === 'GET') {
        $user = Auth::getAuthenticatedUser();
        if (!$user) { http_response_code(401); jsonResponse(['error' => 'Unauthorized']); exit; }
        
        if (!hasPermission($user, 'report_audit')) {
            http_response_code(403); jsonResponse(['error' => 'Forbidden']); exit;
        }

        $startDate = !empty($_GET['start_date']) ? $_GET['start_date'] : null;
        $endDate = !empty($_GET['end_date']) ? $_GET['end_date'] : null;
        $projectId = !empty($_GET['project_id']) ? $_GET['project_id'] : null;
        $ownerId = !empty($_GET['owner_id']) ? $_GET['owner_id'] : null;
        $entryId = !empty($_GET['entry_id']) ? $_GET['entry_id'] : null;
        $onlyRejections = ($_GET['only_rejections'] ?? 'false') === 'true';
        $postApproval = ($_GET['post_approval'] ?? 'false') === 'true';

        $query = "
            SELECT 
                l.*,
                COALESCE(u_actor.name, 'Sistema') as actor_name,
                t.user_id as owner_id,
                u_owner.name as owner_name,
                p.name as project_name,
                tk.name as task_name,
                t.hours as entry_hours,
                t.date as entry_date,
                t.description as entry_description,
                t.created_at as entry_created_at,
                (SELECT COUNT(*) FROM time_entry_logs sub_l WHERE sub_l.time_entry_id = l.time_entry_id AND sub_l.to_status = 'rejected') as rejection_count
            FROM time_entry_logs l
            LEFT JOIN time_entries t ON l.time_entry_id = t.id
            LEFT JOIN users u_owner ON t.user_id = u_owner.id
            LEFT JOIN users u_actor ON l.user_id = u_actor.id
            LEFT JOIN projects p ON t.project_id = p.id
            LEFT JOIN tasks_master tk ON t.task_id = tk.id
            WHERE 1=1
        ";
        $params = [];

        if ($startDate) {
            $query .= " AND l.created_at >= ?";
            $params[] = $startDate . ' 00:00:00';
        }
        if ($endDate) {
            $query .= " AND l.created_at <= ?";
            $params[] = $endDate . ' 23:59:59';
        }
        if ($projectId) {
            $query .= " AND t.project_id = ?";
            $params[] = $projectId;
        }
        if ($ownerId) {
            $query .= " AND t.user_id = ?";
            $params[] = $ownerId;
        }
        if ($entryId) {
            $query .= " AND t.id = ?";
            $params[] = $entryId;
        }

        if ($onlyRejections || $postApproval) {
            $conditions = [];
            if ($onlyRejections) {
                $conditions[] = "l.to_status = 'rejected'";
            }
            if ($postApproval) {
                $conditions[] = "l.from_status = 'approved'";
            }
            $query .= " AND (" . implode(" OR ", $conditions) . ")";
        }

        $query .= " ORDER BY l.created_at DESC LIMIT 500";

        jsonResponse(Database::fetchAll($query, $params));
        exit;
    }

    // 2. System Config
    if ($path === 'config') {
        if ($method === 'GET') {
            $config = Database::fetchOne("SELECT * FROM system_config WHERE id = 1");
            jsonResponse($config);
        } elseif ($method === 'POST') {
            $user = Auth::getAuthenticatedUser();
            if (!hasPermission($user, 'settings')) {
                http_response_code(403);
                jsonResponse(['message' => 'No autorizado']);
                exit;
            }
            
            $body = getBody();
            Database::query("
                UPDATE system_config SET 
                    company_name = ?, logo_url = ?, primary_color = ?, 
                    secondary_color = ?, accent_color = ?, sidebar_bg = ?, 
                    sidebar_text = ?, currency = ?, color_approved = ?,
                    color_rejected = ?, color_submitted = ?, color_draft = ?
                WHERE id = 1
            ", [
                $body['company_name'], $body['logo_url'], $body['primary_color'],
                $body['secondary_color'], $body['accent_color'], $body['sidebar_bg'],
                $body['sidebar_text'], $body['currency'], $body['color_approved'],
                $body['color_rejected'], $body['color_submitted'], $body['color_draft']
            ]);
            jsonResponse(['success' => true]);
        }
        exit;
    }

    // 3. Permissions
    if ($path === 'permissions') {
        if ($method === 'GET') {
            $perms = Database::fetchAll("SELECT role_id, feature, can_access FROM permissions");
            jsonResponse($perms);
        } elseif ($method === 'POST') {
            $user = Auth::getAuthenticatedUser();
            if (!hasPermission($user, 'settings')) {
                http_response_code(403);
                exit;
            }
            $body = getBody();
            Database::query("
                INSERT INTO permissions (role_id, feature, can_access) 
                VALUES (?, ?, ?) 
                ON DUPLICATE KEY UPDATE can_access = VALUES(can_access)
            ", [$body['role_id'], $body['feature'], $body['can_access']]);
            jsonResponse(['success' => true]);
        }
        exit;
    }

    // 4. Dashboard Stats
    if ($path === 'dashboard' && $method === 'GET') {
        $user = Auth::getAuthenticatedUser();
        if (!$user) { http_response_code(401); exit; }

        $from = $_GET['from'] ?? null;
        $to = $_GET['to'] ?? null;
        $clientId = $_GET['client_id'] ?? null;
        $projectId = $_GET['project_id'] ?? null;

        $statsWhere = " WHERE 1=1";
        $statsParams = [];
        if (!hasPermission($user, 'approvals') && $user['role'] !== 'admin') {
            $statsWhere .= " AND t.user_id = ?";
            $statsParams[] = $user['id'];
        }
        if ($from) { $statsWhere .= " AND t.date >= ?"; $statsParams[] = $from; }
        if ($to) { $statsWhere .= " AND t.date <= ?"; $statsParams[] = $to; }
        if ($clientId) { $statsWhere .= " AND p.client_id = ?"; $statsParams[] = $clientId; }
        if ($projectId) { $statsWhere .= " AND t.project_id = ?"; $statsParams[] = $projectId; }

        // General Stats
        $totalHours = (float)(Database::fetchOne("
            SELECT SUM(t.hours) as total 
            FROM time_entries t
            JOIN projects p ON t.project_id = p.id
            JOIN users u ON t.user_id = u.id
            $statsWhere AND t.status IN ('approved', 'submitted', 'draft')
        ", $statsParams)['total'] ?? 0);

        $totalEarnings = (float)(Database::fetchOne("
            SELECT SUM(t.hours * u.hourly_cost) as total 
            FROM time_entries t
            JOIN projects p ON t.project_id = p.id
            JOIN users u ON t.user_id = u.id
            $statsWhere AND t.status = 'approved'
        ", $statsParams)['total'] ?? 0);

        $stats = [
            'totalHours' => $totalHours,
            'totalEarnings' => $totalEarnings,
            'activeProjects' => (int)(Database::fetchOne("
                SELECT COUNT(DISTINCT p.id) as total 
                FROM projects p
                JOIN time_entries t ON p.id = t.project_id
                JOIN users u ON t.user_id = u.id
                $statsWhere
            ", $statsParams)['total'] ?? 0),
            'totalClients' => (int)(Database::fetchOne("
                SELECT COUNT(DISTINCT p.client_id) as total 
                FROM projects p
                JOIN time_entries t ON p.id = t.project_id
                JOIN users u ON t.user_id = u.id
                $statsWhere
            ", $statsParams)['total'] ?? 0)
        ];
        
        // Chart global filtering
        $chartWhere = " WHERE 1=1";
        $chartParams = [];
        if (!hasPermission($user, 'approvals') && $user['role'] !== 'admin') {
            $chartWhere .= " AND t.user_id = ?";
            $chartParams[] = $user['id'];
        }
        if ($from) { $chartWhere .= " AND t.date >= ?"; $chartParams[] = $from; }
        if ($to) { $chartWhere .= " AND t.date <= ?"; $chartParams[] = $to; }
        if ($clientId) { $chartWhere .= " AND p.client_id = ?"; $chartParams[] = $clientId; }
        if ($projectId) { $chartWhere .= " AND t.project_id = ?"; $chartParams[] = $projectId; }
        
        $hoursByProject = Database::fetchAll("
            SELECT p.name, 
                   SUM(CASE WHEN t.status = 'approved' THEN t.hours ELSE 0 END) + 0 as approved,
                   SUM(CASE WHEN t.status = 'submitted' THEN t.hours ELSE 0 END) + 0 as submitted,
                   SUM(CASE WHEN t.status = 'draft' THEN t.hours ELSE 0 END) + 0 as draft,
                   SUM(CASE WHEN t.status = 'rejected' THEN t.hours ELSE 0 END) + 0 as rejected
            FROM projects p 
            LEFT JOIN time_entries t ON p.id = t.project_id 
            LEFT JOIN users u ON t.user_id = u.id
            $chartWhere
            GROUP BY p.id, p.name
            HAVING (approved + submitted + draft + rejected) > 0
        ", $chartParams);

        $hoursByTask = Database::fetchAll("
            SELECT 
                tm.name,
                SUM(CASE WHEN t.status = 'approved' THEN t.hours ELSE 0 END) + 0 as approved,
                SUM(CASE WHEN t.status = 'submitted' THEN t.hours ELSE 0 END) + 0 as submitted,
                SUM(CASE WHEN t.status = 'draft' THEN t.hours ELSE 0 END) + 0 as draft,
                SUM(CASE WHEN t.status = 'rejected' THEN t.hours ELSE 0 END) + 0 as rejected
            FROM tasks_master tm 
            JOIN time_entries t ON tm.id = t.task_id 
            JOIN projects p ON t.project_id = p.id
            JOIN users u ON t.user_id = u.id
            $statsWhere
            GROUP BY tm.id, tm.name
            HAVING (approved + submitted + draft + rejected) > 0
        ", $statsParams);

        $hoursByStatus = Database::fetchOne("
            SELECT 
                SUM(CASE WHEN t.status = 'approved' THEN t.hours ELSE 0 END) + 0 as approved,
                SUM(CASE WHEN t.status = 'submitted' THEN t.hours ELSE 0 END) + 0 as submitted,
                SUM(CASE WHEN t.status = 'draft' THEN t.hours ELSE 0 END) + 0 as draft,
                SUM(CASE WHEN t.status = 'rejected' THEN t.hours ELSE 0 END) + 0 as rejected
            FROM time_entries t
            JOIN projects p ON t.project_id = p.id
            JOIN users u ON t.user_id = u.id
            $statsWhere
        ", $statsParams);

        $userStats = null;
        if (in_array($user['role'], ['staff', 'commercial'])) {
            // For staff, show ALL their hours in their personal dashboard
            $userWhere = " WHERE t.user_id = ?";
            $userParams = [$user['id']];
            if ($from) { $userWhere .= " AND t.date >= ?"; $userParams[] = $from; }
            if ($to) { $userWhere .= " AND t.date <= ?"; $userParams[] = $to; }
            if ($clientId) { $userWhere .= " AND p.client_id = ?"; $userParams[] = $clientId; }
            if ($projectId) { $userWhere .= " AND t.project_id = ?"; $userParams[] = $projectId; }

            $userEarnings = 0;
            if (hasPermission($user, 'costs')) {
                $userEarnings = (float)(Database::fetchOne("
                    SELECT SUM(t.hours * u.hourly_cost) as total 
                    FROM time_entries t
                    JOIN projects p ON t.project_id = p.id
                    JOIN users u ON t.user_id = u.id
                    $userWhere
                ", $userParams)['total'] ?? 0);
            }

            $userStats = [
                'totalHours' => (float)(Database::fetchOne("
                    SELECT SUM(t.hours) as total 
                    FROM time_entries t
                    JOIN projects p ON t.project_id = p.id
                    $userWhere
                ", $userParams)['total'] ?? 0),
                'totalEarnings' => $userEarnings,
                'hoursByProject' => Database::fetchAll("
                    SELECT p.name, SUM(t.hours) + 0 as hours 
                    FROM projects p 
                    JOIN time_entries t ON p.id = t.project_id 
                    $userWhere
                    GROUP BY p.id, p.name
                ", $userParams),
                'hoursByTask' => Database::fetchAll("
                    SELECT 
                        tm.name,
                        SUM(CASE WHEN t.status = 'approved' THEN t.hours ELSE 0 END) + 0 as approved,
                        SUM(CASE WHEN t.status = 'submitted' THEN t.hours ELSE 0 END) + 0 as submitted,
                        SUM(CASE WHEN t.status = 'draft' THEN t.hours ELSE 0 END) + 0 as draft,
                        SUM(CASE WHEN t.status = 'rejected' THEN t.hours ELSE 0 END) + 0 as rejected
                    FROM tasks_master tm 
                    JOIN time_entries t ON tm.id = t.task_id 
                    JOIN projects p ON t.project_id = p.id
                    $userWhere
                    GROUP BY tm.id, tm.name
                    HAVING (approved + submitted + draft + rejected) > 0
                ", $userParams)
            ];
        }

        // Profitability calculation (Admins/C-Level only)
        $profitability = [];
        $profitabilityPagination = null;
        if (hasPermission($user, 'costs')) {
            $pLimit = isset($_GET['limit']) ? (int)$_GET['limit'] : null;
            $pPage = isset($_GET['page']) ? (int)$_GET['page'] : 1;
            $pOffset = ($pPage - 1) * $pLimit;

            $countSql = "SELECT COUNT(DISTINCT p.id) as total 
                         FROM projects p 
                         JOIN time_entries t ON t.project_id = p.id 
                         $statsWhere AND t.status IN ('approved', 'submitted')";
            $pTotal = (int)Database::fetchOne($countSql, $statsParams)['total'];

            $sql = "
                SELECT p.name, 
                       SUM(t.hours * COALESCE(pc.hourly_cost, 0)) as revenue,
                       SUM(t.hours * COALESCE(u.hourly_cost, 0)) as cost
                FROM projects p
                JOIN time_entries t ON t.project_id = p.id
                LEFT JOIN users u ON t.user_id = u.id
                LEFT JOIN position_costs pc ON u.position_id = pc.position_id AND u.seniority = pc.seniority
                $statsWhere AND t.status IN ('approved', 'submitted')
                GROUP BY p.id, p.name
                ORDER BY MAX(t.date) DESC";
            
            if ($pLimit) {
                $sql .= " LIMIT ? OFFSET ?";
                $statsParams[] = (int)$pLimit;
                $statsParams[] = (int)$pOffset;
            }

            $profitability = Database::fetchAll($sql, $statsParams);
            $sumsSql = "
                SELECT SUM(t.hours * COALESCE(pc.hourly_cost, 0)) as totalRevenue,
                       SUM(t.hours * COALESCE(u.hourly_cost, 0)) as totalCost
                FROM projects p
                JOIN time_entries t ON t.project_id = p.id
                LEFT JOIN users u ON t.user_id = u.id
                LEFT JOIN position_costs pc ON u.position_id = pc.position_id AND u.seniority = pc.seniority
                $statsWhere AND t.status IN ('approved', 'submitted')";
            $sums = Database::fetchOne($sumsSql, $statsParams);

            $profitabilityPagination = [
                'total' => $pTotal,
                'page' => $pPage,
                'limit' => $pLimit,
                'totalPages' => $pLimit ? ceil($pTotal / $pLimit) : 1,
                'globalRevenue' => (float)($sums['totalRevenue'] ?? 0),
                'globalCost' => (float)($sums['totalCost'] ?? 0)
            ];
        }
        
        jsonResponse([
            'stats' => $stats,
            'hoursByProject' => $hoursByProject,
            'hoursByTask' => $hoursByTask,
            'hoursByStatus' => $hoursByStatus,
            'profitability' => $profitability,
            'userStats' => $userStats,
            'pagination' => $profitabilityPagination
        ]);
        exit;
    }

    // 5. Clients CRUD
    if ($path === 'clients') {
        $user = Auth::getAuthenticatedUser();
        if (!$user) { http_response_code(401); exit; }

        if ($method === 'GET') {
            if (!hasPermission($user, 'clients')) { http_response_code(403); exit; }
            $participating = isset($_GET['participating']) && $_GET['participating'] === 'true';
            
            $sql = "
                SELECT c.*, 
                       (SELECT COALESCE(SUM(budget_hours), 0) FROM projects WHERE client_id = c.id) as total_budget_hours";

            if (hasPermission($user, 'costs')) {
                $sql .= ",
                       (SELECT COALESCE(SUM(budget_money), 0) FROM projects WHERE client_id = c.id) as total_budget_money,
                       (SELECT COALESCE(SUM(te.hours * pc.hourly_cost), 0) 
                        FROM time_entries te 
                        JOIN projects p ON te.project_id = p.id 
                        JOIN users u ON te.user_id = u.id
                        JOIN position_costs pc ON u.position_id = pc.position_id AND u.seniority = pc.seniority
                        WHERE p.client_id = c.id AND te.status = 'approved') as total_actual_revenue";
            }

            $sql .= ",
                       (SELECT COALESCE(SUM(te.hours), 0) FROM time_entries te JOIN projects p ON te.project_id = p.id WHERE p.client_id = c.id AND te.status = 'approved') as total_actual_hours
                FROM clients c
            ";

            if (hasPermission($user, 'approvals') || !$participating) {
                jsonResponse(Database::fetchAll($sql . " ORDER BY c.name"));
            } else {
                // For staff/commercial, only show clients they have worked with
                jsonResponse(Database::fetchAll($sql . " 
                    WHERE c.id IN (
                        SELECT DISTINCT p2.client_id 
                        FROM projects p2 
                        JOIN time_entries t2 ON p2.id = t2.project_id 
                        WHERE t2.user_id = ?
                    )
                    ORDER BY c.name
                ", [$user['id']]));
            }
        } elseif ($method === 'POST') {
            if (!hasPermission($user, 'clients')) { http_response_code(403); exit; }
            $body = getBody();
            Database::query("INSERT INTO clients (name, legal_name, tax_id, address) VALUES (?, ?, ?, ?)", [
                $body['name'], $body['legal_name'] ?? null, $body['tax_id'] ?? null, $body['address'] ?? null
            ]);
            jsonResponse(['success' => true, 'id' => Database::getInstance()->lastInsertId()]);
        } elseif ($method === 'PUT') {
            if (!hasPermission($user, 'clients')) { http_response_code(403); exit; }
            $body = getBody();
            Database::query("UPDATE clients SET name = ?, legal_name = ?, tax_id = ?, address = ? WHERE id = ?", [
                $body['name'], $body['legal_name'] ?? null, $body['tax_id'] ?? null, $body['address'] ?? null, $body['id']
            ]);
            jsonResponse(['success' => true]);
        }
        exit;
    }

    if (preg_match('/^clients\/(\d+)$/', $path, $matches)) {
        $id = $matches[1];
        if ($method === 'GET') {
            if (!hasPermission($user, 'clients')) { http_response_code(403); exit; }
            $client = Database::fetchOne("SELECT * FROM clients WHERE id = ?", [$id]);
            if ($client) {
                $client['contacts'] = Database::fetchAll("SELECT * FROM client_contacts WHERE client_id = ?", [$id]);
                jsonResponse($client);
            } else {
                http_response_code(404);
                jsonResponse(['message' => 'Cliente no encontrado']);
            }
        }
        exit;
    }

    // 5.1 Client Contacts
    if (preg_match('/^clients\/(\d+)\/contacts$/', $path, $matches)) {
        $clientId = $matches[1];
        if ($method === 'GET') {
            jsonResponse(Database::fetchAll("SELECT * FROM client_contacts WHERE client_id = ?", [$clientId]));
        } elseif ($method === 'POST') {
            $body = getBody();
            Database::query("INSERT INTO client_contacts (client_id, name, email, phone, position) VALUES (?, ?, ?, ?, ?)", [
                $clientId, $body['name'], $body['email'] ?? null, $body['phone'] ?? null, $body['position'] ?? null
            ]);
            jsonResponse(['success' => true, 'id' => Database::getInstance()->lastInsertId()]);
        }
        exit;
    }

    if (preg_match('/^clients\/contacts\/(\d+)$/', $path, $matches)) {
        $id = $matches[1];
        if ($method === 'PUT') {
            $body = getBody();
            Database::query("UPDATE client_contacts SET name = ?, email = ?, phone = ?, position = ? WHERE id = ?", [
                $body['name'], $body['email'] ?? null, $body['phone'] ?? null, $body['position'] ?? null, $id
            ]);
            jsonResponse(['success' => true]);
        } elseif ($method === 'DELETE') {
            Database::query("DELETE FROM client_contacts WHERE id = ?", [$id]);
            jsonResponse(['success' => true]);
        }
        exit;
    }

    // 6. Projects CRUD
    if ($path === 'projects') {
        $user = Auth::getAuthenticatedUser();
        if (!$user) { http_response_code(401); exit; }

        if ($method === 'GET') {
            if (!hasPermission($user, 'projects')) { http_response_code(403); exit; }
            $participating = isset($_GET['participating']) && $_GET['participating'] === 'true';
            
            $limit = isset($_GET['limit']) ? (int)$_GET['limit'] : null;
            $page = isset($_GET['page']) ? (int)$_GET['page'] : 1;
            $offset = ($page - 1) * $limit;

            $where = " WHERE 1=1";
            $params = [];

            if (isset($_GET['status']) && !empty($_GET['status'])) {
                $where .= " AND p.status = ?";
                $params[] = $_GET['status'];
            }

            if (!hasPermission($user, 'approvals') && $participating) {
                // For staff/commercial, only show projects they have worked on
                $where .= " AND p.id IN (SELECT DISTINCT project_id FROM time_entries WHERE user_id = ?)";
                $params[] = $user['id'];
            }

            // Total count
            $countSql = "SELECT COUNT(*) as total FROM projects p $where";
            $total = (int)Database::fetchOne($countSql, $params)['total'];

            $sql = "
                SELECT p.*, c.name as client_name,
                       COALESCE(SUM(t.hours), 0) as actual_hours,
                       COALESCE(SUM(t.hours * u.hourly_cost), 0) as actual_cost,
                       COALESCE(SUM(t.hours * pc.hourly_cost), 0) as actual_revenue
                FROM projects p 
                JOIN clients c ON p.client_id = c.id 
                LEFT JOIN time_entries t ON p.id = t.project_id AND t.status = 'approved'
                LEFT JOIN users u ON t.user_id = u.id
                LEFT JOIN position_costs pc ON u.position_id = pc.position_id AND u.seniority = pc.seniority
                $where
                GROUP BY p.id
                ORDER BY p.status ASC, p.created_at DESC
            ";

            if ($limit) {
                $sql .= " LIMIT ? OFFSET ?";
                $params[] = $limit;
                $params[] = $offset;
            }

            $data = Database::fetchAll($sql, $params);
            jsonResponse([
                'data' => $data,
                'total' => $total,
                'page' => $page,
                'limit' => $limit,
                'totalPages' => $limit ? ceil($total / $limit) : 1
            ]);
        } elseif ($method === 'POST') {
            if (!hasPermission($user, 'projects')) { http_response_code(403); exit; }
            $body = getBody();
            $budgetMoney = hasPermission($user, 'costs') ? ($body['budget_money'] ?? null) : null;
            Database::query("INSERT INTO projects (client_id, name, budget_hours, budget_money, status) VALUES (?, ?, ?, ?, ?)", [
                $body['client_id'], $body['name'], $body['budget_hours'], $budgetMoney, $body['status'] ?? 'Activo'
            ]);
            jsonResponse(['success' => true]);
        } elseif ($method === 'PUT') {
            if (!hasPermission($user, 'projects')) { http_response_code(403); exit; }
            $body = getBody();
            
            if (hasPermission($user, 'costs')) {
                Database::query("UPDATE projects SET client_id = ?, name = ?, budget_hours = ?, budget_money = ?, status = ? WHERE id = ?", [
                    $body['client_id'], $body['name'], $body['budget_hours'], $body['budget_money'], $body['status'], $body['id']
                ]);
            } else {
                Database::query("UPDATE projects SET client_id = ?, name = ?, budget_hours = ?, status = ? WHERE id = ?", [
                    $body['client_id'], $body['name'], $body['budget_hours'], $body['status'], $body['id']
                ]);
            }
            jsonResponse(['success' => true]);
        }
        exit;
    }

    // 7. Time Entries CRUD
    if ($path === 'time-entries' || strpos($path, 'time-entries/') === 0) {
        if ($method === 'GET' && $path === 'time-entries') {
            $user = Auth::getAuthenticatedUser();
            if (!$user) { http_response_code(401); exit; }
            
            $limit = isset($_GET['limit']) ? (int)$_GET['limit'] : null;
            $page = isset($_GET['page']) ? (int)$_GET['page'] : 1;
            $offset = ($page - 1) * $limit;

            $where = " WHERE 1=1";
            $params = [];
            
            if ($user['role'] === 'staff' || $user['role'] === 'commercial') {
                $where .= " AND t.user_id = ?";
                $params[] = $user['id'];
            }
            
            // Filters
            if (isset($_GET['status']) && $_GET['status'] !== 'all') {
                $where .= " AND t.status = ?";
                $params[] = $_GET['status'];
            }
            if (isset($_GET['from']) && !empty($_GET['from'])) {
                $where .= " AND t.date >= ?";
                $params[] = $_GET['from'];
            }
            if (isset($_GET['to']) && !empty($_GET['to'])) {
                $where .= " AND t.date <= ?";
                $params[] = $_GET['to'];
            }

            // Total count
            $countSql = "SELECT COUNT(*) as total FROM time_entries t $where";
            $total = (int)Database::fetchOne($countSql, $params)['total'];

            $sql = "SELECT t.*, p.name as project_name, tm.name as task_name, u.name as user_name, ua.name as approved_by_name
                    FROM time_entries t 
                    JOIN projects p ON t.project_id = p.id 
                    JOIN tasks_master tm ON t.task_id = tm.id
                    JOIN users u ON t.user_id = u.id
                    LEFT JOIN users ua ON t.reviewed_by = ua.id";
            
            $sql .= $where . " ORDER BY t.date DESC, t.created_at DESC";
            
            if ($limit) {
                $sql .= " LIMIT ? OFFSET ?";
                $params[] = $limit;
                $params[] = $offset;
            }
            
            $data = Database::fetchAll($sql, $params);
            jsonResponse([
                'data' => $data,
                'total' => $total,
                'page' => $page,
                'limit' => $limit,
                'totalPages' => $limit ? ceil($total / $limit) : 1
            ]);
            exit;
        } elseif ($method === 'POST' && $path === 'time-entries') {
            $user = Auth::getAuthenticatedUser();
            if (!$user) { http_response_code(401); exit; }
            
            $body = getBody();
            $targetUserId = $user['id'];

            // Admins and Managers can register for others (Kanban requirement or management)
            if (isset($body['user_id']) && ($user['role'] === 'admin' || hasPermission($user, 'users'))) {
                $targetUserId = $body['user_id'];
            } elseif ($user['role'] === 'admin') {
                // Admin MUST specify a user_id since they can't register for themselves
                http_response_code(400);
                jsonResponse(['message' => 'El administrador debe especificar un usuario para el registro.']);
                exit;
            }
            
            // Check if project is active
            $project = Database::fetchOne("SELECT status FROM projects WHERE id = ?", [$body['project_id']]);
            if (!$project || $project['status'] !== 'Activo') {
                http_response_code(400);
                jsonResponse(['message' => 'No se pueden imputar horas a un proyecto que no esté ACTIVO']);
                exit;
            }

            Database::query("
                INSERT INTO time_entries (user_id, project_id, task_id, description, hours, date, status) 
                VALUES (?, ?, ?, ?, ?, ?, ?)
            ", [
                $targetUserId, $body['project_id'], $body['task_id'], 
                $body['description'], $body['hours'], $body['date'], 
                $body['status'] ?? 'submitted'
            ]);
            $id = Database::getInstance()->lastInsertId();
            logTransition($id, null, $body['status'] ?? 'submitted', $user['id'], 'Registro vía Kanban/Manual');
            jsonResponse(['success' => true, 'id' => $id]);
        } elseif ($method === 'PUT' && $path === 'time-entries') {
            $user = Auth::getAuthenticatedUser();
            if (!$user) { http_response_code(401); exit; }
            $body = getBody();
            $id = $body['id'] ?? null;
            if (!$id) { http_response_code(400); jsonResponse(['message' => 'ID requerido']); exit; }
            
            $entry = Database::fetchOne("SELECT * FROM time_entries WHERE id = ?", [$id]);
            if (!$entry) { http_response_code(404); exit; }

            // Check if project is active
            $project = Database::fetchOne("SELECT status FROM projects WHERE id = ?", [$body['project_id']]);
            if (!$project || $project['status'] !== 'Activo') {
                http_response_code(400);
                jsonResponse(['message' => 'No se pueden imputar horas a un proyecto que no esté ACTIVO']);
                exit;
            }
            
            // RBAC: Only owner can edit, and only if draft, pending or rejected
            if ((int)$entry['user_id'] !== (int)$user['id'] && $user['role'] !== 'admin') {
                http_response_code(403);
                exit;
            }
            
            if (!in_array($entry['status'], ['draft', 'pending', 'rejected']) && $user['role'] !== 'admin') {
                http_response_code(400);
                jsonResponse(['message' => 'Solo se pueden editar registros en estado Borrador o Rechazado']);
                exit;
            }
            
            Database::query("
                UPDATE time_entries SET 
                    project_id = ?, task_id = ?, description = ?, hours = ?, date = ?
                WHERE id = ?
            ", [
                $body['project_id'], $body['task_id'], $body['description'], 
                $body['hours'], $body['date'], $id
            ]);
            jsonResponse(['success' => true]);
        } elseif ($method === 'PATCH' && preg_match('/^time-entries\/(\d+)\/submit$/', $path, $matches)) {
            $user = Auth::getAuthenticatedUser();
            if (!$user) { http_response_code(401); exit; }
            $id = $matches[1];
            
            $entry = Database::fetchOne("SELECT * FROM time_entries WHERE id = ?", [$id]);
            if (!$entry) { http_response_code(404); exit; }
            
            if ($entry['user_id'] != $user['id']) { http_response_code(403); exit; }
            
            if (!in_array($entry['status'], ['draft', 'rejected'])) {
                http_response_code(400);
                jsonResponse(['message' => 'Estado inválido para envío']);
                exit;
            }
            
            Database::query("UPDATE time_entries SET status = 'submitted', submitted_at = NOW() WHERE id = ?", [$id]);
            logTransition($id, $entry['status'], 'submitted', $user['id'], 'Enviado para aprobación');
            
            // Notify Approvers
            $approvers = Database::fetchAll("
                SELECT u.id 
                FROM users u 
                LEFT JOIN permissions p ON u.role = p.role AND p.feature = 'approvals'
                WHERE u.role = 'admin' OR p.can_access = 1
            ");
            foreach ($approvers as $approver) {
                createNotification($approver['id'], "Nueva carga de horas de " . $user['name'] . " pendiente de aprobación.", 'info');
            }
            
            jsonResponse(['success' => true]);
        } elseif ($method === 'PATCH' && preg_match('/^time-entries\/(\d+)\/status$/', $path, $matches)) {
            $user = Auth::getAuthenticatedUser();
            if (!$user || !hasPermission($user, 'approvals')) {
                http_response_code(403);
                exit;
            }
            $id = $matches[1];
            $body = getBody();
            $newStatus = $body['status'];
            
            $entry = Database::fetchOne("SELECT * FROM time_entries WHERE id = ?", [$id]);
            if (!$entry) { http_response_code(404); exit; }
            
            // Validate status transition
            if (!in_array($newStatus, ['approved', 'rejected', 'draft'])) {
                http_response_code(400);
                jsonResponse(['message' => 'Estado inválido']);
                exit;
            }

            // Admin Revert logic
            if ($newStatus === 'draft' && $entry['status'] === 'approved') {
                if ($user['role'] !== 'admin') {
                    http_response_code(403);
                    jsonResponse(['message' => 'Solo un administrador puede revertir un registro aprobado']);
                    exit;
                }
            }

            $sql = "UPDATE time_entries SET status = ?, reviewed_by = ?, rejection_reason = ?";
            $params = [$newStatus, $user['id'], $body['rejection_reason'] ?? null];
            
            if ($newStatus === 'approved') {
                $sql .= ", approved_at = NOW()";
            } elseif ($newStatus === 'rejected') {
                $sql .= ", rejected_at = NOW()";
            }
            
            $sql .= " WHERE id = ?";
            $params[] = $id;

            Database::query($sql, $params);
            logTransition($id, $entry['status'], $newStatus, $user['id'], $body['comment'] ?? ($newStatus === 'rejected' ? 'Rechazado: ' . $body['rejection_reason'] : 'Cambio de estado'));
            
            // Create notification for user
            $msg = "Tu registro de horas del " . $entry['date'] . " ha sido " . ($newStatus === 'approved' ? 'APROBADO' : ($newStatus === 'rejected' ? 'RECHAZADO' : 'revertido a Borrador'));
            createNotification($entry['user_id'], $msg, $newStatus === 'approved' ? 'success' : ($newStatus === 'rejected' ? 'error' : 'warning'));
            
            jsonResponse(['success' => true]);
        } elseif ($method === 'POST' && $path === 'time-entries/bulk-status') {
            $user = Auth::getAuthenticatedUser();
            if (!$user || !hasPermission($user, 'approvals')) {
                http_response_code(403);
                exit;
            }
            $body = getBody();
            $ids = $body['ids'] ?? [];
            $newStatus = $body['status'];
            
            if (empty($ids) || !in_array($newStatus, ['approved', 'rejected'])) {
                http_response_code(400);
                exit;
            }
            
            foreach ($ids as $id) {
                $entry = Database::fetchOne("SELECT * FROM time_entries WHERE id = ?", [$id]);
                if (!$entry || $entry['status'] !== 'submitted') continue;
                
                $sql = "UPDATE time_entries SET status = ?, reviewed_by = ?, " . ($newStatus === 'approved' ? 'approved_at' : 'rejected_at') . " = NOW() WHERE id = ?";
                Database::query($sql, [$newStatus, $user['id'], $id]);
                logTransition($id, 'submitted', $newStatus, $user['id'], 'Aprobación masiva');
                
                $msg = "Tu registro de horas del " . $entry['date'] . " ha sido " . ($newStatus === 'approved' ? 'APROBADO' : 'RECHAZADO');
                createNotification($entry['user_id'], $msg, $newStatus === 'approved' ? 'success' : 'error');
            }
            jsonResponse(['success' => true]);
        } elseif ($method === 'DELETE' && preg_match('/^time-entries\/(\d+)$/', $path, $matches)) {
            $user = Auth::getAuthenticatedUser();
            if (!$user) { http_response_code(401); exit; }
            $id = $matches[1];
            
            $entry = Database::fetchOne("SELECT * FROM time_entries WHERE id = ?", [$id]);
            if (!$entry) { http_response_code(404); exit; }
            
            if ((int)$entry['user_id'] !== (int)$user['id'] && $user['role'] !== 'admin') {
                http_response_code(403);
                exit;
            }
            
            Database::query("DELETE FROM time_entries WHERE id = ?", [$id]);
            jsonResponse(['success' => true]);
        } elseif ($method === 'GET' && preg_match('/^time-entries\/(\d+)\/logs$/', $path, $matches)) {
            $user = Auth::getAuthenticatedUser();
            if (!$user) { http_response_code(401); exit; }
            
            $id = $matches[1];
            
            if (!hasPermission($user, 'approvals')) {
                $entry = Database::fetchOne("SELECT user_id FROM time_entries WHERE id = ?", [$id]);
                if (!$entry || $entry['user_id'] != $user['id']) {
                    http_response_code(403);
                    exit;
                }
            }

            jsonResponse(Database::fetchAll("
                SELECT l.*, COALESCE(u.name, 'Sistema') as user_name 
                FROM time_entry_logs l 
                LEFT JOIN users u ON l.user_id = u.id 
                WHERE l.time_entry_id = ? 
                ORDER BY l.created_at DESC
            ", [$id]));
        }
        exit;
    }

    // 6.1 Kanban Tasks CRUD
    if (strpos($path, 'kanban-tasks') === 0) {
        $user = Auth::getAuthenticatedUser();
        if (!$user) { http_response_code(401); exit; }

        if ($method === 'GET' && $path === 'kanban-tasks') {
            $sql = "SELECT kt.*, p.name as project_name, u.name as user_name, tm.name as task_type_name
                    FROM kanban_tasks kt
                    JOIN projects p ON kt.project_id = p.id
                    JOIN users u ON kt.user_id = u.id
                    LEFT JOIN tasks_master tm ON kt.task_type_id = tm.id
                    WHERE 1=1";
            $params = [];

            $isManager = hasPermission($user, 'approvals');

            if (!$isManager && $user['role'] !== 'admin') {
                $sql .= " AND (kt.user_id = ? OR kt.created_by = ?)";
                $params[] = $user['id'];
                $params[] = $user['id'];
            } elseif (isset($_GET['user_id']) && !empty($_GET['user_id'])) {
                $sql .= " AND kt.user_id = ?";
                $params[] = $_GET['user_id'];
            }

            $sql .= " ORDER BY kt.created_at DESC";
            $result = Database::fetchAll($sql, $params) ?: [];
            
            // Ensure we return an array
            jsonResponse(array_values($result));
        } elseif ($method === 'POST' && $path === 'kanban-tasks') {
            $body = getBody();
            $isManager = hasPermission($user, 'approvals') || $user['role'] === 'admin';
            $targetUserId = $isManager && isset($body['user_id']) ? $body['user_id'] : $user['id'];
            
            $sql = "INSERT INTO kanban_tasks (project_id, user_id, description, priority, task_type_id, estimated_hours, status, created_by) 
                    VALUES (?, ?, ?, ?, ?, ?, 'ToDo', ?)";
            $id = Database::query($sql, [
                $body['project_id'],
                $targetUserId,
                $body['description'],
                $body['priority'] ?? 'Baja',
                $body['task_type_id'] ?? null,
                $body['estimated_hours'] ?? 0,
                $user['id']
            ]);
            jsonResponse(['id' => $id, 'success' => true]);
        } elseif ($method === 'PUT' && preg_match('/^kanban-tasks\/(\d+)$/', $path, $matches)) {
            $id = $matches[1];
            $body = getBody();
            $task = Database::fetchOne("SELECT * FROM kanban_tasks WHERE id = ?", [$id]);
            if (!$task) { http_response_code(404); exit; }

            // Admin, Manager OR Owner/Creator can move/edit
            $isManager = hasPermission($user, 'approvals') || (int)$user['role_id'] === 1;
            if (!$isManager && $task['user_id'] != $user['id'] && $task['created_by'] != $user['id']) {
                http_response_code(403);
                exit;
            }

            $newStatus = $body['status'] ?? $task['status'];
            $started_at = $task['started_at'];
            $completed_at = $task['completed_at'];

            // Logic for status transitions
            if ($newStatus === 'Doing' && $task['status'] !== 'Doing') {
                $started_at = date('Y-m-d H:i:s');
            } elseif ($newStatus === 'Done' && $task['status'] !== 'Done') {
                $completed_at = date('Y-m-d H:i:s');
            } elseif ($newStatus === 'Doing' && $task['status'] === 'Done') {
                // Re-trabajo: reset timer
                $started_at = date('Y-m-d H:i:s');
                $completed_at = null;
            }

            $sql = "UPDATE kanban_tasks SET 
                    project_id = ?, 
                    description = ?, 
                    priority = ?, 
                    task_type_id = ?, 
                    estimated_hours = ?, 
                    status = ?, 
                    started_at = ?, 
                    completed_at = ?
                    WHERE id = ?";
            Database::query($sql, [
                $body['project_id'] ?? $task['project_id'],
                $body['description'] ?? $task['description'],
                $body['priority'] ?? $task['priority'],
                $body['task_type_id'] ?? $task['task_type_id'],
                $body['estimated_hours'] ?? $task['estimated_hours'],
                $newStatus,
                $started_at,
                $completed_at,
                $id
            ]);
            jsonResponse(['success' => true]);
        } elseif ($method === 'DELETE' && preg_match('/^kanban-tasks\/(\d+)$/', $path, $matches)) {
            $id = $matches[1];
            $task = Database::fetchOne("SELECT user_id, created_by FROM kanban_tasks WHERE id = ?", [$id]);
            if (!$task) { http_response_code(404); exit; }
            $isManager = hasPermission($user, 'users') || (int)$user['role_id'] === 1;
            if (!$isManager && $task['user_id'] != $user['id'] && $task['created_by'] != $user['id']) {
                http_response_code(403);
                exit;
            }
            Database::query("DELETE FROM kanban_tasks WHERE id = ?", [$id]);
            jsonResponse(['success' => true]);
        }
        exit;
    }

    // 7.1 Metadata
    if ($path === 'metadata' && $method === 'GET') {
        $profiles = Database::fetchAll("SELECT * FROM positions ORDER BY name");
        $seniorities = []; // Not used as table in PHP version
        $tasks = Database::fetchAll("SELECT * FROM tasks_master ORDER BY name");
        jsonResponse([
            'profiles' => $profiles,
            'seniorities' => $seniorities,
            'tasks' => $tasks
        ]);
        exit;
    }

    // 8. Tasks Master
    if ($path === 'tasks') {
        if ($method === 'GET') {
            $limit = isset($_GET['limit']) ? (int)$_GET['limit'] : null;
            $page = isset($_GET['page']) ? (int)$_GET['page'] : 1;
            $offset = ($page - 1) * $limit;

            $total = (int)Database::fetchOne("SELECT COUNT(*) as total FROM tasks_master")['total'];
            $sql = "SELECT * FROM tasks_master ORDER BY name";
            $params = [];
            if ($limit) {
                $sql .= " LIMIT ? OFFSET ?";
                $params[] = (int)$limit;
                $params[] = (int)$offset;
            }

            jsonResponse([
                'data' => Database::fetchAll($sql, $params),
                'total' => $total,
                'page' => $page,
                'limit' => $limit,
                'totalPages' => $limit ? ceil($total / $limit) : 1
            ]);
        } elseif ($method === 'POST') {
            $user = Auth::getAuthenticatedUser();
            if (!hasPermission($user, 'settings')) { http_response_code(403); exit; }
            $body = getBody();
            Database::query("INSERT INTO tasks_master (name, is_archived) VALUES (?, ?)", [
                $body['name'], 
                isset($body['is_archived']) ? ($body['is_archived'] ? 1 : 0) : 0
            ]);
            jsonResponse(['success' => true]);
        } elseif ($method === 'PUT') {
            $user = Auth::getAuthenticatedUser();
            if (!hasPermission($user, 'settings')) { http_response_code(403); exit; }
            $body = getBody();
            Database::query("UPDATE tasks_master SET name = ?, is_archived = ? WHERE id = ?", [
                $body['name'], 
                isset($body['is_archived']) ? ($body['is_archived'] ? 1 : 0) : 0,
                $body['id']
            ]);
            jsonResponse(['success' => true]);
        }
        exit;
    }

    // 8.1 Positions Master
    if ($path === 'positions') {
        $user = Auth::getAuthenticatedUser();
        if (!$user) { http_response_code(401); exit; }

        if ($method === 'GET') {
            $limit = isset($_GET['limit']) ? (int)$_GET['limit'] : null;
            $page = isset($_GET['page']) ? (int)$_GET['page'] : 1;
            $offset = ($page - 1) * $limit;

            $total = (int)Database::fetchOne("SELECT COUNT(*) as total FROM positions")['total'];
            $sql = "SELECT * FROM positions ORDER BY name";
            $params = [];
            if ($limit) {
                $sql .= " LIMIT ? OFFSET ?";
                $params[] = (int)$limit;
                $params[] = (int)$offset;
            }

            jsonResponse([
                'data' => Database::fetchAll($sql, $params),
                'total' => $total,
                'page' => $page,
                'limit' => $limit,
                'totalPages' => $limit ? ceil($total / $limit) : 1
            ]);
        } elseif ($method === 'POST') {
            if ($user['role'] !== 'admin') { http_response_code(403); exit; }
            $body = getBody();
            if (empty($body['name'])) {
                http_response_code(400);
                jsonResponse(['message' => 'El nombre del cargo es requerido']);
                exit;
            }
            try {
                Database::query("INSERT INTO positions (name) VALUES (?)", [$body['name']]);
                jsonResponse(['success' => true]);
            } catch (Throwable $e) {
                http_response_code(500);
                jsonResponse(['message' => 'Error al crear el cargo: ' . $e->getMessage()]);
            }
        } elseif ($method === 'PUT') {
            if (!hasPermission($user, 'settings')) { http_response_code(403); exit; }
            $body = getBody();
            Database::query("UPDATE positions SET name = ? WHERE id = ?", [$body['name'], $body['id']]);
            jsonResponse(['success' => true]);
        }
        exit;
    }

    // 8.2 Position Costs
    if ($path === 'position-costs') {
        $user = Auth::getAuthenticatedUser();
        if (!$user) { http_response_code(401); exit; }

        if ($method === 'GET') {
            if (!hasPermission($user, 'costs')) { http_response_code(403); exit; }
            $limit = isset($_GET['limit']) ? (int)$_GET['limit'] : null;
            $page = isset($_GET['page']) ? (int)$_GET['page'] : 1;
            $offset = ($page - 1) * $limit;

            $total = (int)Database::fetchOne("
                SELECT COUNT(*) as total 
                FROM position_costs
            ")['total'];
            $sql = "
                SELECT pc.*, p.name as position_name 
                FROM position_costs pc 
                JOIN positions p ON pc.position_id = p.id 
                ORDER BY p.name, pc.seniority";
            
            $params = [];
            if ($limit) {
                $sql .= " LIMIT ? OFFSET ?";
                $params[] = (int)$limit;
                $params[] = (int)$offset;
            }

            jsonResponse([
                'data' => Database::fetchAll($sql, $params),
                'total' => $total,
                'page' => $page,
                'limit' => $limit,
                'totalPages' => $limit ? ceil($total / $limit) : 1
            ]);
        } elseif ($method === 'POST') {
            if (!hasPermission($user, 'costs')) { http_response_code(403); exit; }
            $body = getBody();
            Database::query("
                INSERT INTO position_costs (position_id, seniority, hourly_cost) 
                VALUES (?, ?, ?) 
                ON DUPLICATE KEY UPDATE hourly_cost = VALUES(hourly_cost)
            ", [$body['position_id'], $body['seniority'], $body['hourly_cost']]);
            jsonResponse(['success' => true]);
        } elseif ($method === 'PUT') {
            if (!hasPermission($user, 'costs')) { http_response_code(403); exit; }
            $body = getBody();
            Database::query("
                UPDATE position_costs SET position_id = ?, seniority = ?, hourly_cost = ? 
                WHERE id = ?
            ", [$body['position_id'], $body['seniority'], $body['hourly_cost'], $body['id']]);
            jsonResponse(['success' => true]);
        }
        exit;
    }

    // 9. Users CRUD
    if ($path === 'users') {
        $user = Auth::getAuthenticatedUser();
        if (!$user) { http_response_code(401); exit; }

        if ($method === 'GET') {
            // Anyone can fetch the user list for dropdowns etc. No permission check here,
            // but we will mask sensitive data if they don't have the appropriate permissions.
            
            $limit = isset($_GET['limit']) ? (int)$_GET['limit'] : null;
            $page = isset($_GET['page']) ? (int)$_GET['page'] : 1;
            $offset = ($page - 1) * $limit;

            // Total count
            $total = (int)Database::fetchOne("SELECT COUNT(*) as total FROM users")['total'];

            $sql = "
                SELECT u.id, u.name, u.email, u.role, u.role_id, u.position_id, u.seniority, u.hourly_cost, u.weekly_capacity, u.created_at, p.name as position_name 
                FROM users u 
                LEFT JOIN positions p ON u.position_id = p.id 
                ORDER BY u.name
            ";

            $params = [];
            if ($limit) {
                $sql .= " LIMIT ? OFFSET ?";
                $params[] = $limit;
                $params[] = $offset;
            }

            $users = Database::fetchAll($sql, $params);

            // Secure sensitive info if the user shouldn't see it (e.g. costs/admin details)
            $canSeeAll = hasPermission($user, 'costs') || hasPermission($user, 'users');
            if (!$canSeeAll) {
                foreach ($users as &$u) {
                    unset($u['hourly_cost']);
                    unset($u['weekly_capacity']);
                }
            }

            jsonResponse([
                'data' => $users,
                'total' => $total,
                'page' => $page,
                'limit' => $limit,
                'totalPages' => $limit ? ceil($total / $limit) : 1
            ]);
        } elseif ($method === 'POST') {
            if (!hasPermission($user, 'users')) { http_response_code(403); exit; }
            $body = getBody();
            $hashed = password_hash($body['password'], PASSWORD_DEFAULT);
            Database::query("INSERT INTO users (name, email, password, role, role_id, position_id, seniority, hourly_cost, weekly_capacity) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)", [
                $body['name'], $body['email'], $hashed, $body['role'], $body['role_id'] ?? 4, $body['position_id'] ?? null, $body['seniority'] ?? null, $body['hourly_cost'] ?? 0, $body['weekly_capacity'] ?? 40
            ]);
            jsonResponse(['success' => true]);
        } elseif ($method === 'PUT') {
            if (!hasPermission($user, 'users')) { http_response_code(403); exit; }
            $body = getBody();
            $id = $body['id'] ?? null;
            if (!$id) {
                http_response_code(400);
                jsonResponse(['message' => 'ID de usuario requerido']);
                exit;
            }

            $params = [$body['name'], $body['email'], $body['role'], $body['role_id'] ?? 4, $body['position_id'] ?? null, $body['seniority'] ?? null, $body['hourly_cost'] ?? 0, $body['weekly_capacity'] ?? 40];
            $sql = "UPDATE users SET name = ?, email = ?, role = ?, role_id = ?, position_id = ?, seniority = ?, hourly_cost = ?, weekly_capacity = ?";
            
            if (!empty($body['password'])) {
                $sql .= ", password = ?";
                $params[] = password_hash($body['password'], PASSWORD_DEFAULT);
            }
            
            $sql .= " WHERE id = ?";
            $params[] = $id;
            
            Database::query($sql, $params);
            jsonResponse(['success' => true]);
        }
        exit;
    }

    // 10. Delete Endpoints (Generic with dependency checks)
    if (preg_match('/^([a-z-]+)\/(\d+)$/', $path, $matches) && $method === 'DELETE') {
        $user = Auth::getAuthenticatedUser();
        if (!$user) { http_response_code(401); exit; }
        
        $resource = $matches[1];
        
        // Map resource to feature for permission check
        $permMap = [
            'users' => 'users',
            'clients' => 'clients',
            'projects' => 'projects',
            'positions' => 'settings',
            'tasks' => 'settings'
        ];
        
        if (!hasPermission($user, $permMap[$resource] ?? 'admin')) {
            http_response_code(403);
            exit;
        }
        
        $table = str_replace('-', '_', $resource);
        $id = $matches[2];
        
        // Dependency checks
        if ($resource === 'users') {
            $used = Database::fetchOne("SELECT id FROM time_entries WHERE user_id = ? LIMIT 1", [$id]);
            if ($used) {
                http_response_code(400);
                jsonResponse(['message' => 'No se puede eliminar el usuario porque tiene horas registradas en el tracker.']);
                exit;
            }
        } elseif ($resource === 'clients') {
            $used = Database::fetchOne("SELECT id FROM projects WHERE client_id = ? LIMIT 1", [$id]);
            if ($used) {
                http_response_code(400);
                jsonResponse(['message' => 'No se puede eliminar el cliente porque tiene proyectos asociados.']);
                exit;
            }
        } elseif ($resource === 'projects') {
            $used = Database::fetchOne("SELECT id FROM time_entries WHERE project_id = ? LIMIT 1", [$id]);
            if ($used) {
                http_response_code(400);
                jsonResponse(['message' => 'No se puede eliminar el proyecto porque tiene horas registradas.']);
                exit;
            }
        } elseif ($resource === 'positions') {
            $table = 'positions';
            $usedInUsers = Database::fetchOne("SELECT id FROM users WHERE position_id = ? LIMIT 1", [$id]);
            $usedInCosts = Database::fetchOne("SELECT id FROM position_costs WHERE position_id = ? LIMIT 1", [$id]);
            if ($usedInUsers || $usedInCosts) {
                http_response_code(400);
                jsonResponse(['message' => 'No se puede eliminar el cargo porque está siendo utilizado por usuarios o tiene costos asociados.']);
                exit;
            }
        } elseif ($resource === 'tasks') {
            $table = 'tasks_master';
            $used = Database::fetchOne("SELECT id FROM time_entries WHERE task_id = ? LIMIT 1", [$id]);
            if ($used) {
                http_response_code(400);
                jsonResponse(['message' => 'No se puede eliminar la tarea porque tiene registros de horas asociados.']);
                exit;
            }
        }
        
        Database::query("DELETE FROM `$table` WHERE id = ?", [$id]);
        jsonResponse(['success' => true]);
        exit;
    }

    // 11. Notifications (Endpoint: user-alerts to avoid ad blockers)
    if ($path === 'user-alerts') {
        $user = Auth::getAuthenticatedUser();
        if (!$user) { http_response_code(401); exit; }
        
        if ($method === 'GET') {
            jsonResponse(Database::fetchAll("SELECT * FROM notifications WHERE user_id = ? ORDER BY created_at DESC LIMIT 50", [$user['id']]));
        } elseif ($method === 'PATCH') {
            $body = getBody();
            if (isset($body['id'])) {
                Database::query("UPDATE notifications SET is_read = 1 WHERE id = ? AND user_id = ?", [$body['id'], $user['id']]);
            } else {
                Database::query("UPDATE notifications SET is_read = 1 WHERE user_id = ?", [$user['id']]);
            }
            jsonResponse(['success' => true]);
        }
        exit;
    }

    // 12. Profile
    if ($path === 'profile') {
        $user = Auth::getAuthenticatedUser();
        if (!$user) { http_response_code(401); exit; }
        
        if ($method === 'GET') {
            $fullUser = Database::fetchOne("SELECT id, name, email, role, role_id, position_id, seniority, language FROM users WHERE id = ?", [$user['id']]);
            jsonResponse($fullUser);
        } elseif ($method === 'PUT') {
            $body = getBody();
            $params = [$body['name'], $body['email'], $body['language'] ?? 'es_AR'];
            $sql = "UPDATE users SET name = ?, email = ?, language = ?";
            
            if (!empty($body['password'])) {
                $sql .= ", password = ?";
                $params[] = password_hash($body['password'], PASSWORD_DEFAULT);
            }
            
            $sql .= " WHERE id = ?";
            $params[] = $user['id'];
            
            Database::query($sql, $params);
            jsonResponse(['success' => true]);
        }
        exit;
    }

        if ($path === 'predictive-alerts' && $method === 'GET') {
        $user = Auth::getAuthenticatedUser();
        if (!$user || !hasPermission($user, 'report_ai')) {
            http_response_code(403);
            exit;
        }

        $projects = Database::fetchAll("
            SELECT id, name, budget_hours, budget_money, status 
            FROM projects 
            WHERE status = 'Activo' AND budget_hours > 0
        ");

        $alerts = [];
        foreach ($projects as $project) {
            $projectId = $project['id'];
            
            // 1. Burn Rate Calculation
            $consumedHours = (float)Database::fetchOne("
                SELECT SUM(hours) as total 
                FROM time_entries 
                WHERE project_id = ? AND status IN ('approved', 'submitted')
            ", [$projectId])['total'] ?? 0;

            // Avg hours per week in last 4 weeks
            $avgWeekly = (float)Database::fetchOne("
                SELECT SUM(hours) / 4 as avg_weekly
                FROM time_entries
                WHERE project_id = ? 
                  AND status IN ('approved', 'submitted')
                  AND date >= DATE_SUB(CURDATE(), INTERVAL 4 WEEK)
            ", [$projectId])['avg_weekly'] ?? 0;

            // 2. Margin Risk Detection (Seniority)
            $seniorHours = (float)Database::fetchOne("
                SELECT SUM(t.hours) as total
                FROM time_entries t
                JOIN users u ON t.user_id = u.id
                WHERE t.project_id = ? AND u.seniority = 'Senior' AND t.status IN ('approved', 'submitted')
            ", [$projectId])['total'] ?? 0;

            $totalHours = $consumedHours;
            $seniorPercent = $totalHours > 0 ? ($seniorHours / $totalHours) * 100 : 0;

            $budgetExhaustedPercent = ($consumedHours / $project['budget_hours']) * 100;
            $remainingHours = $project['budget_hours'] - $consumedHours;
            $weeksToDepletion = $avgWeekly > 0 ? $remainingHours / $avgWeekly : null;

            // Determine Priority
            $priority = 'Low';
            if ($budgetExhaustedPercent > 90 || ($weeksToDepletion !== null && $weeksToDepletion < 2)) {
                $priority = 'High';
            } elseif ($budgetExhaustedPercent > 70 || $seniorPercent > 50) {
                $priority = 'Medium';
            }

            // Create Alert Object (Metrics for AI) - All active projects
            $alerts[] = [
                'projectId' => $projectId,
                'projectName' => $project['name'],
                'priority' => $priority,
                'metrics' => [
                    'budget_hours' => (float)$project['budget_hours'],
                    'consumed_hours' => $consumedHours,
                    'budget_exhausted_percent' => round($budgetExhaustedPercent, 1),
                    'avg_weekly_hours' => round($avgWeekly, 1),
                    'weeks_to_depletion' => $weeksToDepletion !== null ? round($weeksToDepletion, 1) : 'Indefinido',
                    'seniority_mix' => [
                        'senior_percent' => round($seniorPercent, 1)
                    ]
                ]
            ];
        }

        jsonResponse(['alerts' => $alerts]);
        exit;
    }

    // 404
    http_response_code(404);
    jsonResponse([
        'message' => 'Endpoint no encontrado: ' . $path,
        'debug' => [
            'method' => $method,
            'uri' => $_SERVER['REQUEST_URI'],
            'get_path' => $_GET['path'] ?? null
        ]
    ]);

} catch (Throwable $e) {
    http_response_code(500);
    jsonResponse(['message' => 'Error interno: ' . $e->getMessage()]);
}
