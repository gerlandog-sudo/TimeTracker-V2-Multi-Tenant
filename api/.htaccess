Options +FollowSymLinks
RewriteEngine On

# Definir la base relativa para la carpeta api
# RewriteBase /api/

# Redirigir si no es un archivo o directorio físico
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)$ index.php?path=$1 [QSA,L]

# Seguridad
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>
